{
  "productName": "体重一键记录(成就版)",
  "version": "0.1.0",
  "identifier": "com.aiprojects.weight-achiever",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "体重一键记录(成就版)",
        "width": 900,
        "height": 680,
        "resizable": true,
        "center": true,
        "minWidth": 600,
        "minHeight": 500
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
